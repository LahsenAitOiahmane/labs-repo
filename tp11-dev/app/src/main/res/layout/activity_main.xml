<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ═══════════════════════════════════════════════
             HERO HEADER — app title + GPS pulse animation
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/headerSection"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#050F1F"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <!-- GPS pulse animation frame -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center">

                <!-- Outer ring 1 (furthest) -->
                <View
                    android:id="@+id/pulseRing3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_pulse_ring"
                    android:alpha="0" />

                <!-- Outer ring 2 (mid) -->
                <View
                    android:id="@+id/pulseRing2"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_pulse_ring"
                    android:alpha="0" />

                <!-- Core GPS dot -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_pulse_core"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_gps"
                        android:contentDescription="@string/cd_gps_icon" />
                </FrameLayout>
            </FrameLayout>

            <!-- App title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/app_subtitle"
                android:textColor="#7DB5CC"
                android:textSize="13sp"
                android:letterSpacing="0.02" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             STATUS BAR
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical"
            android:background="#080E1A">

            <!-- Status indicator dot -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_pulse_ring" />

            <TextView
                android:id="@+id/tvStatusMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/status_gps_searching"
                android:textColor="#7DB5CC"
                android:textSize="13sp" />

            <!-- Records counter -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip_info"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_send"
                    android:contentDescription="@string/cd_send_icon" />

                <TextView
                    android:id="@+id/tvSentCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="0"
                    android:textColor="#1AA3D4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             COORDINATES CARD
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cardCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_satellite"
                    android:contentDescription="@string/cd_signal_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/header_coordinates"
                    android:textColor="#7DB5CC"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <!-- Signal quality chip -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <LinearLayout
                    android:id="@+id/signalChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_info"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp">

                    <TextView
                        android:id="@+id/tvSignalQuality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="En attente"
                        android:textColor="#1AA3D4"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1D4E73"
                android:layout_marginBottom="16dp" />

            <!-- Latitude row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_latitude"
                        android:textColor="#4A7A8F"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvLatitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/placeholder_waiting"
                        android:textColor="#E8F4F8"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Lat indicator line -->
                <View
                    android:layout_width="3dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:background="#0D7EA8" />
            </LinearLayout>

            <!-- Longitude row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_longitude"
                        android:textColor="#4A7A8F"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvLongitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/placeholder_waiting"
                        android:textColor="#E8F4F8"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Long indicator line -->
                <View
                    android:layout_width="3dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:background="#00C9A7" />
            </LinearLayout>

            <!-- Precision + Timestamp row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Precision -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_accuracy"
                        android:textColor="#4A7A8F"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="#7DB5CC"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Timestamp -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_timestamp"
                        android:textColor="#4A7A8F"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvTimestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="#7DB5CC"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             DEVICE INFO CARD
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cardDevice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_device"
                    android:contentDescription="@string/cd_gps_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/header_device_info"
                    android:textColor="#7DB5CC"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1D4E73"
                android:layout_marginBottom="14dp" />

            <!-- Device ID label + value -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_device_id"
                android:textColor="#4A7A8F"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tvDeviceId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/placeholder_waiting"
                android:textColor="#D0E8F5"
                android:textSize="14sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             SERVER CONFIG CARD
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cardServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_server"
                    android:contentDescription="@string/cd_server_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/header_server"
                    android:textColor="#7DB5CC"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1D4E73"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_server_url"
                android:textColor="#4A7A8F"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tvServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="http://192.168.137.1:80/localisation/createPosition.php"
                android:textColor="#00C9A7"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <!-- Last sent row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="@string/cd_gps_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/label_last_sent"
                    android:textColor="#4A7A8F"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvLastSent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="—"
                    android:textColor="#7DB5CC"
                    android:textSize="12sp"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             ACTION BUTTONS
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <!-- START TRACKING -->
            <Button
                android:id="@+id/btnStartTracking"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_start_tracking"
                android:background="@drawable/bg_btn_primary"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:elevation="4dp" />

            <!-- STOP TRACKING -->
            <Button
                android:id="@+id/btnStopTracking"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/btn_stop_tracking"
                android:background="@drawable/bg_btn_danger"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:enabled="false"
                android:elevation="4dp" />
        </LinearLayout>

        <!-- SEND NOW button — full width -->
        <Button
            android:id="@+id/btnSendNow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:text="@string/btn_send_now"
            android:background="@drawable/bg_btn_primary"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:enabled="false"
            android:elevation="4dp"
            android:drawableStart="@drawable/ic_send"
            android:drawablePadding="8dp" />

        <!-- ═══════════════════════════════════════════════
             ACTIVITY LOG CARD
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cardLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Log header with clear button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Journal d'activité"
                    android:textColor="#7DB5CC"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <Button
                    android:id="@+id/btnClearLog"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/btn_clear_log"
                    android:textColor="#4A7A8F"
                    android:textSize="11sp"
                    android:textAllCaps="false"
                    android:background="@android:color/transparent"
                    android:paddingHorizontal="4dp" />
            </LinearLayout>

            <!-- Log text area -->
            <ScrollView
                android:id="@+id/logScrollView"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvActivityLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="@drawable/bg_log_area"
                    android:text=""
                    android:textColor="#7DB5CC"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.6" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>