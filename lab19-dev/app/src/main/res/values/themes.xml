<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.Lab19" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/accent_violet</item>
        <item name="colorSecondary">@color/accent_violet</item>
        <item name="colorSecondaryVariant">@color/accent_rose</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
    </style>

    <style name="Theme.Lab19" parent="Base.Theme.Lab19" />

    <!-- FAB style -->
    <style name="NoteKeeper.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/accent_cyan</item>
        <item name="tint">@color/bg_primary</item>
    </style>

    <!-- Button style -->
    <style name="NoteKeeper.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_cyan</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Button Danger style -->
    <style name="NoteKeeper.Button.Danger" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/accent_rose</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Note card style -->
    <style name="NoteKeeper.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <!-- EditText / TextInputLayout style -->
    <style name="NoteKeeper.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxStrokeColor">@color/accent_cyan</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- BottomSheet style -->
    <style name="NoteKeeper.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@color/bg_surface</item>
        <item name="android:background">@color/bg_surface</item>
    </style>
</resources>