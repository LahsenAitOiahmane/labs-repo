<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="40dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@color/divider" />

    <!-- Title section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Nouvelle note"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Title input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_title"
        style="@style/NoteKeeper.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:hint="@string/label_note_title"
        app:startIconDrawable="@android:drawable/ic_menu_edit"
        app:startIconTint="@color/accent_cyan">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_note_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Body input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_body"
        style="@style/NoteKeeper.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="@string/label_note_body"
        app:startIconDrawable="@android:drawable/ic_menu_agenda"
        app:startIconTint="@color/accent_violet">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_note_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="4"
            android:maxLines="8"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sheet_cancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="@string/btn_cancel"
            android:textColor="@color/text_secondary"
            app:cornerRadius="10dp"
            app:strokeColor="@color/divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sheet_save"
            style="@style/NoteKeeper.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_note"
            app:icon="@android:drawable/ic_menu_save"
            app:iconTint="@color/bg_primary" />

    </LinearLayout>

</LinearLayout>
