<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/pv_card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Avatar circulaire avec initiale -->
        <TextView
            android:id="@+id/tv_avatar_initial"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="?" />

        <!-- Infos du contact -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tv_entry_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nom du contact"
                android:textColor="@color/pv_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_entry_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+000 000 000"
                android:textColor="@color/pv_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Indicateur de source -->
        <TextView
            android:id="@+id/tv_entry_origin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="android"
            android:textColor="@color/pv_accent"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:background="#1A00BFA5"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
