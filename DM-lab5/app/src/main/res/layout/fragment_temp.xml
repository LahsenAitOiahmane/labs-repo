<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/lbl_temp_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Température"
            android:textColor="@color/primary_brand"
            android:textSize="20sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/group_unit_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/choice_c_to_f"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Celsius vers Fahrenheit" />

            <RadioButton
                android:id="@+id/choice_f_to_c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fahrenheit vers Celsius" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_temp_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Valeur à convertir"
                android:inputType="numberDecimal|numberSigned" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/action_calc_temp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/accent_color"
            android:text="Convertir maintenant" />

        <TextView
            android:id="@+id/display_temp_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="---"
            android:textColor="@color/primary_brand"
            android:textSize="18sp"
            android:textStyle="italic" />
    </LinearLayout>
</androidx.cardview.widget.CardView>